{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:best-practices"],
  "description": "Automated dependency updates with automerge",
  "automerge": true,
  "platformAutomerge": false,
  "prHourlyLimit": 0,
  "rebaseWhen": "behind-base-branch",
  "packageRules": [
    {
      "description": "Microsoft .NET Docker images: block major updates",
      "matchDatasources": ["docker"],
      "matchPackageNames": [
        "mcr.microsoft.com/dotnet/sdk",
        "mcr.microsoft.com/dotnet/runtime"
      ],
      "matchUpdateTypes": ["major"],
      "enabled": false
    },
    {
      "description": "localhost images: disable entirely (test fixture)",
      "matchDatasources": ["docker"],
      "matchPackageNames": [
        "/^localhost/"
      ]
    },
    {
      "description": "NuGet packages: block major updates",
      "matchDatasources": ["nuget"],
      "matchUpdateTypes": ["major"],
      "enabled": false
    }
  ]
}
